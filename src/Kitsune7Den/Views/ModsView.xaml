<UserControl x:Class="Kitsune7Den.Views.ModsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Kitsune7Den.Models"
             Loaded="OnLoaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource SectionHeader}" Text="Mods" Margin="0" />
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"
                           VerticalAlignment="Center" Margin="12,0,0,0">
                    <Run Text="{Binding EnabledCount, Mode=OneWay}" />
                    <Run Text="/" />
                    <Run Text="{Binding TotalCount, Mode=OneWay}" />
                    <Run Text=" enabled" />
                </TextBlock>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Open Folder" Style="{StaticResource SecondaryButton}"
                        Command="{Binding OpenModsFolderCommand}" Margin="0,0,8,0" />
                <Button Content="Refresh" Style="{StaticResource SecondaryButton}"
                        Command="{Binding RefreshCommand}" Margin="0,0,8,0" />
                <Button Style="{StaticResource ActionButton}"
                        Command="{Binding InstallFromZipCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Install from Zip" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Mod Cards -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Mods}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ModInfo}">
                        <Border Background="{DynamicResource BgMediumBrush}" CornerRadius="8"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                Margin="0,0,0,8" Padding="0">
                            <DockPanel>
                                <!-- Enabled/disabled accent -->
                                <Border DockPanel.Dock="Left" Width="4" CornerRadius="8,0,0,8">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource TextSecondaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <Grid Margin="14,10,14,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Mod Info -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <!-- Name + Version + Status -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                                       Text="{Binding Version}" />
                                            <!-- Status badge -->
                                            <Border CornerRadius="3" Padding="6,1" Margin="8,0,0,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="#FF3a2a2a" />
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <SolidColorBrush Color="#FF1a3a2a" />
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="10" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Disabled" />
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                    <Setter Property="Text" Value="Enabled" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>

                                        <!-- Author + Description -->
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                                       Visibility="{Binding Author, Converter={StaticResource StringVis}}">
                                                <Run Text="by " />
                                                <Run Text="{Binding Author, Mode=OneWay}" FontWeight="SemiBold" />
                                            </TextBlock>
                                            <TextBlock Text=" — " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                                       Visibility="{Binding Description, Converter={StaticResource StringVis}}" />
                                            <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" MaxWidth="500" TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding Description, Converter={StaticResource StringVis}}" />
                                        </StackPanel>

                                        <!-- Size + Folder -->
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding SizeText}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="10" />
                                            <TextBlock Text=" | " Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" />
                                            <TextBlock Text="{Binding FolderName}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="10" Opacity="0.6" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <!-- Toggle button -->
                                        <Button Style="{StaticResource SecondaryButton}" Padding="10,5" FontSize="11"
                                                Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Enable" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                <Setter Property="Text" Value="Disable" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                        <!-- Delete button -->
                                        <Button Style="{StaticResource SecondaryButton}" Padding="8,5" FontSize="11"
                                                Margin="6,0,0,0"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="12" Margin="0,8,0,0" />
    </Grid>
</UserControl>
