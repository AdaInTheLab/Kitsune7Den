<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Forest — Dark green tones + amber accent -->
    <Color x:Key="BgDark">#FF141e14</Color>
    <Color x:Key="BgMedium">#FF1a281a</Color>
    <Color x:Key="BgLight">#FF2a3e2a</Color>
    <Color x:Key="Accent">#FFd4a040</Color>
    <Color x:Key="AccentHover">#FFe8b85a</Color>
    <Color x:Key="TextPrimary">#FFd8e0d8</Color>
    <Color x:Key="TextSecondary">#FF7a8a7a</Color>
    <Color x:Key="BorderColor">#FF2a3a2a</Color>
    <Color x:Key="SuccessColor">#FF5cb85c</Color>
    <Color x:Key="WarningColor">#FFe8a040</Color>
</ResourceDictionary>
